# Copy this file to .env and fill in your values
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional: change the model (default: gemini/gemini-2.5-flash)
# GEMINI_MODEL_NAME=gemini/gemini-1.5-pro

# ── Internship Search (optional but recommended) ──────────────────────────────
# Get a free API key at https://serper.dev (2,500 free searches/month)
# When set, the internship search crew uses live Google Search results from
# LinkedIn, Indeed, Glassdoor, Handshake, Wellfound, and company career pages.
# Without this key, the AI agents return curated suggestions from training data.
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE
